{
  "name": "naija-agent-core",
  "version": "1.0.3",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "clean": "rm -rf apps/*/dist packages/*/dist apps/*/.tsbuildinfo packages/*/.tsbuildinfo",
    "build": "npm run clean && node scripts/build.js",
    "dev": "npm run dev --workspaces",
    "start": "npm run start --workspaces",
    "start:api": "node apps/api/dist/index.mjs",
    "start:worker": "node apps/worker/dist/index.mjs"
  },
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/cookie": "^0.6.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^20.11.0",
    "typescript": "^5.3.3",
    "esbuild": "^0.20.1"
  },
  "dependencies": {
    "bcrypt": "^6.0.0",
    "cookie": "^1.1.1",
    "date-fns": "^4.1.0",
    "date-fns-tz": "^3.2.0",
    "jsonwebtoken": "^9.0.3",
    "react": "19.2.4",
    "react-dom": "19.2.4"
  }
}
