{
  "name": "naija-agent-core",
  "version": "1.0.3",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "clean": "rm -rf apps/*/dist packages/*/dist apps/*/.tsbuildinfo packages/*/.tsbuildinfo packages/*/tsconfig.tsbuildinfo",
    "build": "npm run clean && node scripts/build.js",
    "dev": "npm run dev --workspaces",
    "start": "npm run start --workspaces",
    "start:api": "node apps/api/dist/index.js",
    "start:worker": "node apps/worker/dist/index.js"
  },
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/cookie": "^0.6.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^20.11.0",
    "esbuild": "0.20.2",
    "typescript": "5.9.3"
  },
  "dependencies": {
    "bcrypt": "^6.0.0",
    "bytes": "3.1.2",
    "cookie": "^1.1.1",
    "date-fns": "^4.1.0",
    "date-fns-tz": "^3.2.0",
    "depd": "2.0.0",
    "http-errors": "2.0.1",
    "iconv-lite": "0.7.2",
    "inherits": "2.0.4",
    "jsonwebtoken": "^9.0.3",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "setprototypeof": "1.2.0",
    "statuses": "2.0.2",
    "toidentifier": "1.0.1",
    "unpipe": "1.0.0"
  }
}
