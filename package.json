{
  "name": "naija-agent-core",
  "version": "1.0.2",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "clean": "rm -rf apps/*/dist packages/*/dist apps/*/.tsbuildinfo packages/*/.tsbuildinfo",
    "build": "npm run clean && node scripts/build.js",
    "dev": "npm run dev --workspaces",
    "start": "npm run start --workspaces",
    "start:api": "node apps/api/dist/index.mjs",
    "start:worker": "node apps/worker/dist/index.mjs"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "esbuild": "^0.27.3",
    "typescript": "^5.3.3"
  }
}
