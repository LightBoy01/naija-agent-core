{
  "name": "naija-agent-core",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "clean": "rm -rf apps/*/dist packages/*/dist apps/*/.tsbuildinfo packages/*/.tsbuildinfo",
    "build": "npm run clean && tsc -b",
    "dev": "npm run dev --workspaces",
    "start": "npm run start --workspaces",
    "start:api": "npm run start --workspace=@naija-agent/api",
    "start:worker": "npm run start --workspace=@naija-agent/worker"
  },
  "devDependencies": {
    "typescript": "^5.3.3",
    "@types/node": "^20.11.0"
  }
}
