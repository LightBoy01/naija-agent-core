{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "moduleResolution": "node",
    "resolveJsonModule": true,
    "baseUrl": ".",
    "paths": {
      "@naija-agent/types": ["packages/types/src"],
      "@naija-agent/firebase": ["packages/firebase/src"]
    },
    "outDir": "./dist",
    "declaration": true,
    "declarationMap": true,
    "composite": true
  },
  "references": [
    { "path": "packages/types" },
    { "path": "packages/firebase" },
    { "path": "apps/api" },
    { "path": "apps/worker" }
  ],
  "exclude": ["node_modules", "dist"]
}
